<div class="card">
    <div class="shop-header">
        <h1><i class="fas fa-store-alt"></i> Магазин</h1>
        <div class="shop-balance">
            <span class="balance-amount"><%= balance %></span>
            <span class="balance-label">монет</span>
        </div>
        <a href="/" class="btn-back"><i class="fas fa-arrow-left"></i> Назад</a>
    </div>

    <% if (locals.message) { %>
        <div class="message-box" style="margin-bottom: 1rem;"><%= message %></div>
    <% } %>

    <div class="shop-grid">
        <% items.forEach(item => { %>
            <div class="shop-item">
                <div class="item-icon">
                    <i class="fas <%= item.effect_type === 'extra_attempt' ? 'fa-plus-circle' : 'fa-lightbulb' %>"></i>
                </div>
                <h3><%= item.name %></h3>
                <p><%= item.description %></p>
                <div class="item-price"><%= parseFloat(item.price).toFixed(2) %> монет</div>
                <form action="/buy/<%= item.id %>" method="POST">
                    <button type="submit" class="btn-primary buy-btn">Купить</button>
                </form>
            </div>
        <% }) %>
    </div>
</div>

<style>
.shop-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.8rem;
}
.shop-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0;
}
.shop-balance {
    text-align: right;
}
.shop-balance .balance-amount {
    font-size: 1.6rem;
    font-weight: 700;
    color: #00E676;
}
.shop-balance .balance-label {
    font-size: 0.65rem;
    color: #a0a0a0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
}
.shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
}
.shop-item {
    background: #f8f8fa;
    border-radius: 20px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
}
.shop-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
}
.item-icon {
    font-size: 2.5rem;
    color: #00E676;
    margin-bottom: 0.5rem;
}
.shop-item h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0.5rem 0 0.2rem;
}
.shop-item p {
    font-size: 0.9rem;
    color: #666;
    margin: 0.2rem 0 1rem;
}
.item-price {
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 1rem;
    color: #1a1a1a;
}
.buy-btn {
    width: 100%;
    max-width: 160px;
    padding: 0.5rem 1rem;
}
@media (max-width: 600px) {
    .shop-grid { grid-template-columns: 1fr; }
}
</style>